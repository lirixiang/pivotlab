# PivotLab 环境变量配置
# 复制此文件为 .env 并填入你的配置

# LLM 提供商（qwen / deepseek / openai / siliconflow / doubao / glm）
LLM_DEFAULT_PROVIDER=qwen
LLM_DEFAULT_MODEL=qwen-turbo

# API Keys（按使用的提供商填写其中一个即可）
QWEN_API_KEY=
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
SILICONFLOW_API_KEY=
DOUBAO_API_KEY=
GLM_API_KEY=

# 可选：跨域配置（默认允许所有来源）
# CORS_ORIGINS=https://yourdomain.com
